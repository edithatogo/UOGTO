@prefix uogto:  <https://w3id.org/uogto/core#> .
@prefix uogtox: <https://w3id.org/uogto/extensions#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/uogto/extensions/contract-theory> a owl:Ontology ;
    rdfs:label "UOGTO Extension - Contract Theory"@en ;
    owl:imports <https://w3id.org/uogto/core> .

uogtox:ContractGame a owl:Class ;
    rdfs:subClassOf uogto:GameSpecification ;
    rdfs:label "ContractGame"@en ;
    skos:definition "A game modeling strategic principal-agent contracts."@en .

uogtox:PrincipalAgentGame a owl:Class ;
    rdfs:subClassOf uogto:GameSpecification ;
    rdfs:label "PrincipalAgentGame"@en ;
    skos:definition "A game with hidden action or hidden information."@en .

uogtox:Contract a owl:Class ;
    rdfs:subClassOf uogto:GameEntity ;
    rdfs:label "Contract"@en ;
    skos:definition "The binding document detailing incentives."@en .

uogtox:Principal a owl:Class ;
    rdfs:subClassOf uogto:GameEntity ;
    rdfs:label "Principal"@en ;
    skos:definition "The contract designer offering terms."@en .

uogtox:AgentRole a owl:Class ;
    rdfs:subClassOf uogto:Agent ;
    rdfs:label "AgentRole"@en ;
    skos:definition "The strategic contractor accepting terms."@en .

uogtox:IncentiveScheme a owl:Class ;
    rdfs:subClassOf uogto:GameEntity ;
    rdfs:label "IncentiveScheme"@en ;
    skos:definition "A system tying payments to performance indicators."@en .

uogtox:HiddenAction a owl:Class ;
    rdfs:subClassOf uogto:Action ;
    rdfs:label "HiddenAction"@en ;
    skos:definition "An action unobserved by the principal (moral hazard)."@en .

uogtox:HiddenInformation a owl:Class ;
    rdfs:subClassOf uogto:GameEntity ;
    rdfs:label "HiddenInformation"@en ;
    skos:definition "A type unobserved by the principal (adverse selection)."@en .

uogtox:MonitoringTechnology a owl:Class ;
    rdfs:subClassOf uogto:GameEntity ;
    rdfs:label "MonitoringTechnology"@en ;
    skos:definition "A mechanism observing indicators."@en .

uogtox:ParticipationConstraint a owl:Class ;
    rdfs:subClassOf uogto:GameEntity ;
    rdfs:label "ParticipationConstraint"@en ;
    skos:definition "Condition ensuring the agent accepts the contract."@en .

uogtox:hasContract a owl:ObjectProperty ;
    rdfs:label "hasContract"@en ;
    rdfs:domain uogtox:ContractGame ;
    rdfs:range uogtox:Contract ;
    skos:definition "Links a principal-agent game to its contract."@en .

uogtox:hasPrincipal a owl:ObjectProperty ;
    rdfs:label "hasPrincipal"@en ;
    rdfs:domain uogtox:ContractGame ;
    rdfs:range uogtox:Principal ;
    skos:definition "Links a game to its principal."@en .

uogtox:hasAgentRole a owl:ObjectProperty ;
    rdfs:label "hasAgentRole"@en ;
    rdfs:domain uogtox:ContractGame ;
    rdfs:range uogtox:AgentRole ;
    skos:definition "Links a game to its agent role."@en .

uogtox:hasIncentiveScheme a owl:ObjectProperty ;
    rdfs:label "hasIncentiveScheme"@en ;
    rdfs:domain uogtox:Contract ;
    rdfs:range uogtox:IncentiveScheme ;
    skos:definition "Links a contract to incentives."@en .

uogtox:wageValue a owl:DatatypeProperty ;
    rdfs:label "wageValue"@en ;
    rdfs:domain uogtox:IncentiveScheme ;
    rdfs:range xsd:double ;
    skos:definition "Numeric property representing agent payments."@en .

