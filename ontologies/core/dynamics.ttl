@prefix uogto:  <https://w3id.org/uogto/core#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/uogto/core/dynamics> a owl:Ontology ;
    rdfs:label "UOGTO Core - Dynamics Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

uogto:DiscreteDynamics a owl:Class ;
    rdfs:subClassOf uogto:TransitionFunction ;
    rdfs:label "Discrete Dynamics"@en ;
    skos:definition "State transitions occurring in discrete time steps."@en .

uogto:ContinuousDynamics a owl:Class ;
    rdfs:subClassOf uogto:TransitionFunction ;
    rdfs:label "Continuous Dynamics"@en ;
    skos:definition "State transitions occurring over continuous time flows."@en .
