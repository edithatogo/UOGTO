@prefix uogto:  <https://w3id.org/uogto/core#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/uogto/core/actions> a owl:Ontology ;
    rdfs:label "UOGTO Core - Actions Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

uogto:SimultaneousAction a owl:Class ;
    rdfs:subClassOf uogto:Action ;
    rdfs:label "Simultaneous Action"@en ;
    skos:definition "An action taken in synchrony with other players' choices."@en .

uogto:SequentialAction a owl:Class ;
    rdfs:subClassOf uogto:Action ;
    rdfs:label "Sequential Action"@en ;
    skos:definition "An action taken in order during the game's sequence."@en .
