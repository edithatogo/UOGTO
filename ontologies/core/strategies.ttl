@prefix uogto:  <https://w3id.org/uogto/core#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/uogto/core/strategies> a owl:Ontology ;
    rdfs:label "UOGTO Core - Strategies Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

uogto:PureStrategy a owl:Class ;
    rdfs:subClassOf uogto:Strategy ;
    rdfs:label "Pure Strategy"@en ;
    skos:definition "A strategy that defines a specific choice for all decision points."@en .

uogto:MixedStrategy a owl:Class ;
    rdfs:subClassOf uogto:Strategy ;
    rdfs:label "Mixed Strategy"@en ;
    skos:definition "A probability distribution over pure strategies."@en .
