@prefix uogto:  <https://w3id.org/uogto/core#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/uogto/core/information> a owl:Ontology ;
    rdfs:label "UOGTO Core - Information Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

uogto:PerfectInformation a owl:Class ;
    rdfs:subClassOf uogto:InformationSet ;
    rdfs:label "Perfect Information"@en ;
    skos:definition "Information configuration where all past actions are observed."@en .

uogto:ImperfectInformation a owl:Class ;
    rdfs:subClassOf uogto:InformationSet ;
    rdfs:label "Imperfect Information"@en ;
    skos:definition "Information configuration where some past actions are hidden."@en .
