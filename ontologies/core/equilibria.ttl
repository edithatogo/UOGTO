@prefix uogto:  <https://w3id.org/uogto/core#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:   <http://www.w3.org/2004/02/skos/core#> .

<https://w3id.org/uogto/core/equilibria> a owl:Ontology ;
    rdfs:label "UOGTO Core - Equilibria Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

uogto:NashEquilibrium a owl:Class ;
    rdfs:subClassOf uogto:Equilibrium ;
    rdfs:label "Nash Equilibrium"@en ;
    skos:definition "A strategy profile where no player has a unilateral incentive to deviate."@en .

uogto:SubgamePerfectEquilibrium a owl:Class ;
    rdfs:subClassOf uogto:Equilibrium ;
    rdfs:label "Subgame Perfect Equilibrium"@en ;
    skos:definition "An equilibrium that constitutes a Nash equilibrium in every subgame."@en .
