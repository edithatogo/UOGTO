PREFIX uogto: <https://w3id.org/uogto/core#>
PREFIX uogtox: <https://w3id.org/uogto/extensions#>
SELECT ?game ?agent ?population ?policy ?outcome WHERE { ?game a uogtox:MeanFieldGame ; uogtox:hasRepresentativeAgent ?agent ; uogtox:hasPopulationState ?population ; uogto:hasStrategy ?policy ; uogto:producesOutcome ?outcome . }
