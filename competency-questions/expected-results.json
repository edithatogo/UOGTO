{
  "schema": "uogto.competency-query-expectations.v1",
  "queries": [
    {
      "query": "cq01-list-players.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "game": "http://example.org/stag-hunt",
          "player": "http://example.org/hunter-1"
        }
      ]
    },
    {
      "query": "cq02-list-strategies.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "player": "http://example.org/players/p1",
          "strategy": "http://example.org/strategies/cooperate"
        }
      ]
    },
    {
      "query": "cq03-find-equilibria.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "game": "http://example.org/stag-hunt",
          "equilibrium": "http://example.org/stag-stag"
        }
      ]
    },
    {
      "query": "cq04-games-with-incomplete-information.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "game": "http://example.org/signalling-game",
          "infoSet": "http://example.org/sender-info-set"
        }
      ]
    },
    {
      "query": "cq05-security-games-with-targets.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "game": "http://example.org/stackelberg-security",
          "target": "http://example.org/targets/t1"
        }
      ]
    },
    {
      "query": "cq06-mechanisms-with-incentive-constraints.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "mechanism": "http://example.org/first-price-auction",
          "constraint": "http://example.org/constraints/bid-truthfulness-risk"
        }
      ]
    },
    {
      "query": "cq07-llm-games-with-tool-invocations.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "agent": "http://example.org/players/llm-agent-1",
          "toolCall": "http://example.org/tools/search-call-1"
        }
      ]
    },
    {
      "query": "cq08-executable-games-with-event-traces.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "game": "http://example.org/first-price-auction",
          "trace": "http://example.org/traces/auction-trace-1"
        }
      ]
    },
    {
      "query": "cq09-games-with-privacy-budget.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "player": "http://example.org/players/privacy-agent-1",
          "budget": "http://example.org/privacy/budget-1"
        }
      ]
    },
    {
      "query": "cq10-modules-and-imports.rq",
      "min_results": 1,
      "required_bindings": [
        {
          "importedOntology": "https://w3id.org/uogto/core"
        }
      ]
    }
  ]
}
