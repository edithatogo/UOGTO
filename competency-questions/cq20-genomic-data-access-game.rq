PREFIX genomic: <https://w3id.org/uogto/extensions#> PREFIX uogto: <https://w3id.org/uogto/core#>
SELECT ?game ?consent ?custodian ?action ?risk WHERE { ?game a genomic:GenomicDataAccessGame ; uogto:governedByRule ?consent ; uogto:hasPlayer ?custodian ; uogto:producesOutcome ?outcome . ?custodian uogto:selectsAction ?action . ?outcome uogto:assignsPayoff ?risk . }
