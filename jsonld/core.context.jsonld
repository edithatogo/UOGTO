{
  "@context": {
    "uogto": "https://w3id.org/uogto/core#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "prov": "http://www.w3.org/ns/prov#",

    "GameSpecification": "uogto:GameSpecification",
    "GameInstance": "uogto:GameInstance",
    "PlaySession": "uogto:PlaySession",
    "Player": "uogto:Player",
    "Agent": "uogto:Agent",
    "Coalition": "uogto:Coalition",
    "Institution": "uogto:Institution",
    "Role": "uogto:Role",
    "Strategy": "uogto:Strategy",
    "StrategyProfile": "uogto:StrategyProfile",
    "Action": "uogto:Action",
    "ActionProfile": "uogto:ActionProfile",
    "Outcome": "uogto:Outcome",
    "Payoff": "uogto:Payoff",
    "UtilityFunction": "uogto:UtilityFunction",
    "PreferenceRelation": "uogto:PreferenceRelation",
    "State": "uogto:State",
    "InitialState": "uogto:InitialState",
    "TerminalState": "uogto:TerminalState",
    "Transition": "uogto:Transition",
    "TransitionFunction": "uogto:TransitionFunction",
    "InformationSet": "uogto:InformationSet",
    "Belief": "uogto:Belief",
    "Signal": "uogto:Signal",
    "Rule": "uogto:Rule",
    "Norm": "uogto:Norm",
    "Equilibrium": "uogto:Equilibrium",
    "Solver": "uogto:Solver",
    "ExecutionModel": "uogto:ExecutionModel",
    "EventTrace": "uogto:EventTrace",

    "hasPlayer": { "@id": "uogto:hasPlayer", "@type": "@id" },
    "participatesIn": { "@id": "uogto:participatesIn", "@type": "@id" },
    "hasRole": { "@id": "uogto:hasRole", "@type": "@id" },
    "hasStrategy": { "@id": "uogto:hasStrategy", "@type": "@id" },
    "hasAvailableAction": { "@id": "uogto:hasAvailableAction", "@type": "@id" },
    "selectsAction": { "@id": "uogto:selectsAction", "@type": "@id" },
    "hasStrategyProfile": { "@id": "uogto:hasStrategyProfile", "@type": "@id" },
    "producesOutcome": { "@id": "uogto:producesOutcome", "@type": "@id" },
    "assignsPayoff": { "@id": "uogto:assignsPayoff", "@type": "@id" },
    "hasUtilityFunction": { "@id": "uogto:hasUtilityFunction", "@type": "@id" },
    "hasState": { "@id": "uogto:hasState", "@type": "@id" },
    "hasInitialState": { "@id": "uogto:hasInitialState", "@type": "@id" },
    "hasTerminalState": { "@id": "uogto:hasTerminalState", "@type": "@id" },
    "hasTransition": { "@id": "uogto:hasTransition", "@type": "@id" },
    "transitionsFrom": { "@id": "uogto:transitionsFrom", "@type": "@id" },
    "transitionsTo": { "@id": "uogto:transitionsTo", "@type": "@id" },
    "observes": { "@id": "uogto:observes", "@type": "@id" },
    "hasInformationSet": { "@id": "uogto:hasInformationSet", "@type": "@id" },
    "hasBelief": { "@id": "uogto:hasBelief", "@type": "@id" },
    "governedByRule": { "@id": "uogto:governedByRule", "@type": "@id" },
    "governedByNorm": { "@id": "uogto:governedByNorm", "@type": "@id" },
    "hasEquilibrium": { "@id": "uogto:hasEquilibrium", "@type": "@id" },
    "solvedBy": { "@id": "uogto:solvedBy", "@type": "@id" },
    "compiledToExecutionModel": { "@id": "uogto:compiledToExecutionModel", "@type": "@id" },
    "emitsEventTrace": { "@id": "uogto:emitsEventTrace", "@type": "@id" },

    "identifier": { "@id": "uogto:identifier", "@type": "xsd:string" },
    "name": { "@id": "uogto:name", "@type": "xsd:string" },
    "description": { "@id": "uogto:description", "@type": "xsd:string" },
    "version": { "@id": "uogto:version", "@type": "xsd:string" },
    "probability": { "@id": "uogto:probability", "@type": "xsd:double" },
    "payoffValue": { "@id": "uogto:payoffValue", "@type": "xsd:double" },
    "utilityValue": { "@id": "uogto:utilityValue", "@type": "xsd:double" },
    "timeIndex": { "@id": "uogto:timeIndex", "@type": "xsd:integer" },
    "timestamp": { "@id": "uogto:timestamp", "@type": "xsd:dateTime" },
    "confidence": { "@id": "uogto:confidence", "@type": "xsd:double" },
    "sourceReference": { "@id": "uogto:sourceReference", "@type": "xsd:anyURI" }
  }
}
