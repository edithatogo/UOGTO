<https://w3id.org/uogto/extensions#StructuralEquation> a owl:Class ;
    rdfs:label "StructuralEquation"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An equation mapping endogenous variables to exogenous factors."@en .

<https://w3id.org/uogto/extensions#TerminalRule> a owl:Class ;
