@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ns1: <https://w3id.org/uogto/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/uogto/alignments/mcp-a2a> a owl:Ontology ;
    rdfs:label "UOGTO Alignment with Model Context Protocol"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/alignments/open-games> a owl:Ontology ;
    rdfs:label "UOGTO Alignment with Open Games"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/alignments/prov-o> a owl:Ontology ;
    rdfs:label "UOGTO Alignment with PROV-O"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/alignments/schema-org> a owl:Ontology ;
    rdfs:label "UOGTO Alignment with Schema.org"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/alignments/wot-thing-description> a owl:Ontology ;
    rdfs:label "UOGTO Alignment with W3C Web of Things Thing Description"@en ;
    owl:imports <https://w3id.org/uogto/core> .

ns1:ActionProfile a owl:Class ;
    rdfs:label "Action Profile"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A combination of actions chosen simultaneously by all players."@en .

ns1:ArtificialAgent a owl:Class ;
    rdfs:label "Artificial Agent"@en ;
    rdfs:subClassOf ns1:Agent ;
    skos:definition "A software agent participating in a game."@en .

ns1:Belief a owl:Class ;
    rdfs:label "Belief"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A probability distribution over states in an information set."@en .

ns1:CardinalPayoff a owl:Class ;
    rdfs:label "Cardinal Payoff"@en ;
    rdfs:subClassOf ns1:Payoff ;
    skos:definition "A payoff representing quantitative measurements of utility."@en .

ns1:ChanceNode a owl:Class ;
    rdfs:label "Chance Node"@en ;
    rdfs:subClassOf ns1:GameNode ;
    skos:definition "A game node where transition outcomes are decided stochastically."@en .

ns1:ConstitutiveRule a owl:Class ;
    rdfs:label "Constitutive Rule"@en ;
    rdfs:subClassOf ns1:Rule ;
    skos:definition "Rules that create or define new forms of activity."@en .

ns1:ContinuousDynamics a owl:Class ;
    rdfs:label "Continuous Dynamics"@en ;
    rdfs:subClassOf ns1:TransitionFunction ;
    skos:definition "State transitions occurring over continuous time flows."@en .

ns1:DeterministicOutcome a owl:Class ;
    rdfs:label "Deterministic Outcome"@en ;
    rdfs:subClassOf ns1:Outcome ;
    skos:definition "An outcome determined strictly by player actions."@en .

ns1:DiscreteDynamics a owl:Class ;
    rdfs:label "Discrete Dynamics"@en ;
    rdfs:subClassOf ns1:TransitionFunction ;
    skos:definition "State transitions occurring in discrete time steps."@en .

ns1:EventTrace a owl:Class ;
    rdfs:label "Event Trace"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A history of state transitions and actions in a session."@en .

ns1:ExecutionModel a owl:Class ;
    rdfs:label "Execution Model"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A compilation of the game ontology to an executable simulator."@en .

ns1:FiniteGame a owl:Class ;
    rdfs:label "Finite Game"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game with a finite number of players, strategies, and outcomes."@en .

ns1:GameInstance a owl:Class ;
    rdfs:label "Game Instance"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A concrete realization of a GameSpecification, preparing or binding parameters for play."@en .

ns1:HumanPlayer a owl:Class ;
    rdfs:label "Human Player"@en ;
    rdfs:subClassOf ns1:Player ;
    skos:definition "A human agent participating in a game."@en .

ns1:ImperfectInformation a owl:Class ;
    rdfs:label "Imperfect Information"@en ;
    rdfs:subClassOf ns1:InformationSet ;
    skos:definition "Information configuration where some past actions are hidden."@en .

ns1:InfiniteGame a owl:Class ;
    rdfs:label "Infinite Game"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game featuring infinite player or strategy spaces."@en .

ns1:InitialState a owl:Class ;
    rdfs:label "Initial State"@en ;
    rdfs:subClassOf ns1:State ;
    skos:definition "The start state of the game."@en .

ns1:Institution a owl:Class ;
    rdfs:label "Institution"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An organizational frame or system governing game norms."@en .

ns1:MixedStrategy a owl:Class ;
    rdfs:label "Mixed Strategy"@en ;
    rdfs:subClassOf ns1:Strategy ;
    skos:definition "A probability distribution over pure strategies."@en .

ns1:NashEquilibrium a owl:Class ;
    rdfs:label "Nash Equilibrium"@en ;
    rdfs:subClassOf ns1:Equilibrium ;
    skos:definition "A strategy profile where no player has a unilateral incentive to deviate."@en .

ns1:Norm a owl:Class ;
    rdfs:label "Norm"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A social constraint or expectation in institutional games."@en .

ns1:OrdinalPayoff a owl:Class ;
    rdfs:label "Ordinal Payoff"@en ;
    rdfs:subClassOf ns1:Payoff ;
    skos:definition "A payoff representing relative preference rankings."@en .

ns1:PerfectInformation a owl:Class ;
    rdfs:label "Perfect Information"@en ;
    rdfs:subClassOf ns1:InformationSet ;
    skos:definition "Information configuration where all past actions are observed."@en .

ns1:PreferenceRelation a owl:Class ;
    rdfs:label "Preference Relation"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An ordinal ranking of outcomes by a player."@en .

ns1:PureStrategy a owl:Class ;
    rdfs:label "Pure Strategy"@en ;
    rdfs:subClassOf ns1:Strategy ;
    skos:definition "A strategy that defines a specific choice for all decision points."@en .

ns1:RegulativeRule a owl:Class ;
    rdfs:label "Regulative Rule"@en ;
    rdfs:subClassOf ns1:Rule ;
    skos:definition "Rules that regulate pre-existing activities."@en .

ns1:Role a owl:Class ;
    rdfs:label "Role"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A position occupied by a player within a game specification."@en .

ns1:SequentialAction a owl:Class ;
    rdfs:label "Sequential Action"@en ;
    rdfs:subClassOf ns1:Action ;
    skos:definition "An action taken in order during the game's sequence."@en .

ns1:Signal a owl:Class ;
    rdfs:label "Signal"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An informational cue emitted to players."@en .

ns1:SimultaneousAction a owl:Class ;
    rdfs:label "Simultaneous Action"@en ;
    rdfs:subClassOf ns1:Action ;
    skos:definition "An action taken in synchrony with other players' choices."@en .

ns1:StochasticOutcome a owl:Class ;
    rdfs:label "Stochastic Outcome"@en ;
    rdfs:subClassOf ns1:Outcome ;
    skos:definition "An outcome incorporating environmental randomness."@en .

ns1:SubgamePerfectEquilibrium a owl:Class ;
    rdfs:label "Subgame Perfect Equilibrium"@en ;
    rdfs:subClassOf ns1:Equilibrium ;
    skos:definition "An equilibrium that constitutes a Nash equilibrium in every subgame."@en .

ns1:TerminalNode a owl:Class ;
    rdfs:label "Terminal Node"@en ;
    rdfs:subClassOf ns1:GameNode ;
    skos:definition "A terminal node in a game model mapping to payoffs."@en .

ns1:TerminalState a owl:Class ;
    rdfs:label "Terminal State"@en ;
    rdfs:subClassOf ns1:State ;
    skos:definition "A leaf node representing game completion."@en .

ns1:Transition a owl:Class ;
    rdfs:label "Transition"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A state change triggered by an action profile."@en .

ns1:UtilityFunction a owl:Class ;
    rdfs:label "Utility Function"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A mapping from outcomes to real numbers for a player."@en .

ns1:assignsPayoff a owl:ObjectProperty ;
    rdfs:label "assigns payoff"@en ;
    skos:definition "Links an outcome to the payoffs distributed."@en .

ns1:belongsToInformationSet a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "belongs to information set"@en ;
    rdfs:domain ns1:DecisionNode ;
    rdfs:range ns1:InformationSet ;
    skos:definition "Functional relation linking a decision node to its single containing information set."@en .

ns1:competencyQuestionReference a owl:DatatypeProperty ;
    rdfs:label "competency question reference"@en ;
    rdfs:domain ns1:OntologyGovernanceRecord ;
    rdfs:range xsd:string ;
    skos:definition "A compact reference to competency questions linked to the governance record."@en .

ns1:compiledToExecutionModel a owl:ObjectProperty ;
    rdfs:label "compiled to execution model"@en ;
    skos:definition "Links a game to its executable representation."@en .

ns1:comprisesStrategy a owl:ObjectProperty ;
    rdfs:label "comprises strategy"@en ;
    rdfs:domain ns1:StrategyProfile ;
    rdfs:range ns1:Strategy ;
    skos:definition "Links a strategy profile to the specific individual strategies."@en .

ns1:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence"@en ;
    rdfs:range xsd:double ;
    skos:definition "Belief confidence score."@en .

ns1:controlsNode a owl:ObjectProperty ;
    rdfs:label "controls node"@en ;
    rdfs:domain ns1:Player ;
    rdfs:range ns1:DecisionNode ;
    skos:definition "Links a player to the decision node they control."@en .

ns1:description a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    rdfs:range xsd:string ;
    skos:definition "Human-readable description."@en .

ns1:emitsEventTrace a owl:ObjectProperty ;
    rdfs:label "emits event trace"@en ;
    skos:definition "Connects a play session to its event log."@en .

ns1:governanceStatus a owl:DatatypeProperty ;
    rdfs:label "governance status"@en ;
    rdfs:domain ns1:OntologyGovernanceRecord ;
    rdfs:range xsd:string ;
    skos:definition "The current governance state of the ontology, such as active, review, or archived."@en .

ns1:governedByNorm a owl:ObjectProperty ;
    rdfs:label "governed by norm"@en ;
    skos:definition "Norms governing an institution."@en .

ns1:governedByRule a owl:ObjectProperty ;
    rdfs:label "governed by rule"@en ;
    skos:definition "Rules governing a specification or instance."@en .

ns1:hasAvailableAction a owl:ObjectProperty ;
    rdfs:label "has available action"@en ;
    skos:definition "Lists actions available to a player in a state."@en .

ns1:hasBelief a owl:ObjectProperty ;
    rdfs:label "has belief"@en ;
    skos:definition "Links a player's information set to their belief state."@en .

ns1:hasEquilibrium a owl:ObjectProperty ;
    rdfs:label "has equilibrium"@en ;
    skos:definition "Connects a game to its computed equilibrium profile."@en .

ns1:hasGovernanceRecord a owl:ObjectProperty ;
    rdfs:label "has governance record"@en ;
    rdfs:domain owl:Ontology ;
    rdfs:range ns1:OntologyGovernanceRecord ;
    skos:definition "Connects an ontology IRI to its governance record."@en .

ns1:hasInformationSet a owl:ObjectProperty ;
    rdfs:label "has information set"@en ;
    skos:definition "Relates states to an information set."@en .

ns1:hasInitialState a owl:ObjectProperty ;
    rdfs:label "has initial state"@en ;
    skos:definition "Declares the initial state."@en .

ns1:hasPayoff a owl:ObjectProperty ;
    rdfs:label "has payoff"@en ;
    rdfs:domain ns1:StrategyProfile ;
    rdfs:range ns1:PayoffProfile ;
    skos:definition "Links a strategy profile to its corresponding reified payoff profile."@en .

ns1:hasPayoffForPlayer a owl:ObjectProperty ;
    rdfs:label "has payoff for player"@en ;
    rdfs:domain ns1:PayoffProfile ;
    rdfs:range ns1:PlayerPayoffLink ;
    skos:definition "Links a payoff profile to individual player-utility mappings."@en .

ns1:hasPlayer a owl:ObjectProperty ;
    rdfs:label "has player"@en ;
    skos:definition "Associates a game specification or instance with its players."@en .

ns1:hasRole a owl:ObjectProperty ;
    rdfs:label "has role"@en ;
    skos:definition "Assigns a role to a player."@en .

ns1:hasState a owl:ObjectProperty ;
    rdfs:label "has state"@en ;
    skos:definition "Relates a game instance or specification to a state."@en .

ns1:hasStrategy a owl:ObjectProperty ;
    rdfs:label "has strategy"@en ;
    skos:definition "Links a player to their selected or available strategy."@en .

ns1:hasStrategyProfile a owl:ObjectProperty ;
    rdfs:label "has strategy profile"@en ;
    skos:definition "Links a game equilibrium to its constituent strategy profile."@en .

ns1:hasTerminalState a owl:ObjectProperty ;
    rdfs:label "has terminal state"@en ;
    skos:definition "Declares a terminal state."@en .

ns1:hasTransition a owl:ObjectProperty ;
    rdfs:label "has transition"@en ;
    skos:definition "Links states or actions to a transition."@en .

ns1:hasUtilityFunction a owl:ObjectProperty ;
    rdfs:label "has utility function"@en ;
    skos:definition "Assigns a utility function to a player role."@en .

ns1:identifier a owl:DatatypeProperty ;
    rdfs:label "identifier"@en ;
    rdfs:range xsd:string ;
    skos:definition "A unique string identifying a game component."@en .

ns1:maturityLevel a owl:DatatypeProperty ;
    rdfs:label "maturity level"@en ;
    rdfs:domain ns1:OntologyGovernanceRecord ;
    rdfs:range xsd:string ;
    skos:definition "The maturity assessment of the ontology, such as draft, curated, research-grade, or release-ready."@en .

ns1:name a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    rdfs:range xsd:string ;
    skos:definition "The name of a game component."@en .

ns1:observes a owl:ObjectProperty ;
    rdfs:label "observes"@en ;
    skos:definition "Links an agent to an observed signal or state."@en .

ns1:participatesIn a owl:ObjectProperty ;
    rdfs:label "participates in"@en ;
    skos:definition "Associates a player with a game session or specification."@en .

ns1:payoffPlayer a owl:ObjectProperty ;
    rdfs:label "payoff player"@en ;
    rdfs:domain ns1:PlayerPayoffLink ;
    rdfs:range ns1:Player ;
    skos:definition "Associates the player payoff mapping back to the player."@en .

ns1:payoffValue a owl:DatatypeProperty ;
    rdfs:label "payoff value"@en ;
    rdfs:range xsd:double ;
    skos:definition "Numeric value of a player's payoff."@en .

ns1:probability a owl:DatatypeProperty ;
    rdfs:label "probability"@en ;
    rdfs:range xsd:double ;
    skos:definition "Transition or signal probability value (0 to 1)."@en .

ns1:producesOutcome a owl:ObjectProperty ;
    rdfs:label "produces outcome"@en ;
    skos:definition "Relates actions or states to an outcome."@en .

ns1:reviewDate a owl:DatatypeProperty ;
    rdfs:label "review date"@en ;
    rdfs:domain ns1:OntologyGovernanceRecord ;
    rdfs:range xsd:date ;
    skos:definition "The date on which the governance record was last reviewed."@en .

ns1:selectsAction a owl:ObjectProperty ;
    rdfs:label "selects action"@en ;
    skos:definition "Relates a player or agent to the action they choose."@en .

ns1:solvedBy a owl:ObjectProperty ;
    rdfs:label "solved by"@en ;
    skos:definition "Identifies the solver that calculated the equilibrium."@en .

ns1:sourceEvidenceReference a owl:DatatypeProperty ;
    rdfs:label "source evidence reference"@en ;
    rdfs:domain ns1:OntologyGovernanceRecord ;
    rdfs:range xsd:string ;
    skos:definition "A compact reference to evidence surfaces supporting the current governance record."@en .

ns1:sourceReference a owl:DatatypeProperty ;
    rdfs:label "source reference"@en ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI to external citations or source data."@en .

ns1:steward a owl:DatatypeProperty ;
    rdfs:label "steward"@en ;
    rdfs:domain ns1:OntologyGovernanceRecord ;
    rdfs:range xsd:string ;
    skos:definition "The person, team, or role responsible for governance decisions and review."@en .

ns1:timeIndex a owl:DatatypeProperty ;
    rdfs:label "time index"@en ;
    rdfs:range xsd:integer ;
    skos:definition "Discrete time step identifier."@en .

ns1:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp"@en ;
    rdfs:range xsd:dateTime ;
    skos:definition "Real-world time log of an event."@en .

ns1:transitionsFrom a owl:ObjectProperty ;
    rdfs:label "transitions from"@en ;
    skos:definition "Starting state of a transition."@en .

ns1:transitionsTo a owl:ObjectProperty ;
    rdfs:label "transitions to"@en ;
    skos:definition "Target state of a transition."@en .

ns1:utilityValue a owl:DatatypeProperty ;
    rdfs:label "utility value"@en ;
    rdfs:range xsd:double ;
    skos:definition "Calculated utility value of an outcome."@en .

ns1:version a owl:DatatypeProperty ;
    rdfs:label "version"@en ;
    rdfs:range xsd:string ;
    skos:definition "Ontology version metadata."@en .

<https://w3id.org/uogto/core/actions> a owl:Ontology ;
    rdfs:label "UOGTO Core - Actions Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/agents> a owl:Ontology ;
    rdfs:label "UOGTO Core - Agents Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/dynamics> a owl:Ontology ;
    rdfs:label "UOGTO Core - Dynamics Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/equilibria> a owl:Ontology ;
    rdfs:label "UOGTO Core - Equilibria Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/games> a owl:Ontology ;
    rdfs:label "UOGTO Core - Games Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/governance> a owl:Ontology ;
    rdfs:label "UOGTO governance metadata"@en ;
    dcterms:modified "2026-06-24"^^xsd:date ;
    owl:versionInfo "2026-06-24" ;
    skos:definition "Ontology-level governance metadata for status, maturity, stewardship, review timing, source evidence, and competency-question linkage."@en ;
    prov:wasDerivedFrom <https://w3id.org/uogto/core> ;
    ns1:hasGovernanceRecord ns1:currentGovernanceRecord .

<https://w3id.org/uogto/core/information> a owl:Ontology ;
    rdfs:label "UOGTO Core - Information Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/outcomes> a owl:Ontology ;
    rdfs:label "UOGTO Core - Outcomes Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/payoffs> a owl:Ontology ;
    rdfs:label "UOGTO Core - Payoffs Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/rules> a owl:Ontology ;
    rdfs:label "UOGTO Core - Rules Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/core/strategies> a owl:Ontology ;
    rdfs:label "UOGTO Core - Strategies Module"@en ;
    owl:imports <https://w3id.org/uogto/core> .

<https://w3id.org/uogto/extensions#ActionAffordance> a owl:Class ;
    rdfs:label "ActionAffordance"@en ;
    rdfs:subClassOf ns1:Action ;
    skos:definition "Writable control capabilities exposed by a Digital Twin."@en .

<https://w3id.org/uogto/extensions#ActionAttribution> a owl:Class ;
    rdfs:label "ActionAttribution"@en ;
    rdfs:subClassOf ns1:Action ;
    skos:definition "Links an action instance to a signature identity."@en .

<https://w3id.org/uogto/extensions#AgentCapability> a owl:Class ;
    rdfs:label "AgentCapability"@en ;
    rdfs:subClassOf ns1:Agent ;
    skos:definition "Declared functionality of an LLM agent."@en .

<https://w3id.org/uogto/extensions#AgentProtocolSession> a owl:Class ;
    rdfs:label "AgentProtocolSession"@en ;
    rdfs:subClassOf ns1:Agent ;
    skos:definition "A session structured via communication protocols."@en .

<https://w3id.org/uogto/extensions#AlgorithmicSolver> a owl:Class ;
    rdfs:label "Algorithmic Solver"@en ;
    rdfs:subClassOf ns1:Solver ;
    skos:definition "An algorithmic solver resolving game theoretic equilibrium."@en .

<https://w3id.org/uogto/extensions#ApproximationGuarantee> a owl:Class ;
    rdfs:label "ApproximationGuarantee"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The precision bounds of approximate solvers."@en .

<https://w3id.org/uogto/extensions#AttackVector> a owl:Class ;
    rdfs:label "AttackVector"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The path selected by the attacker."@en .

<https://w3id.org/uogto/extensions#AuditEvent> a owl:Class ;
    rdfs:label "AuditEvent"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Log entry reporting compliance violations."@en .

<https://w3id.org/uogto/extensions#CausalPayoffModel> a owl:Class ;
    rdfs:label "CausalPayoffModel"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A causal specification of payoff functions."@en .

<https://w3id.org/uogto/extensions#CoalitionGame> a owl:Class ;
    rdfs:label "Coalition Game"@en ;
    rdfs:subClassOf <https://w3id.org/uogto/extensions#CooperativeGame> ;
    skos:definition "A cooperative game focusing on coalition formations."@en .

<https://w3id.org/uogto/extensions#CognitiveHierarchyModel> a owl:Class ;
    rdfs:label "CognitiveHierarchyModel"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Model tracking continuous hierarchies of player thinking depth."@en .

<https://w3id.org/uogto/extensions#CollectiveChoiceArena> a owl:Class ;
    rdfs:label "CollectiveChoiceArena"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An arena where rules are written or amended."@en .

<https://w3id.org/uogto/extensions#CommonKnowledge> a owl:Class ;
    rdfs:label "CommonKnowledge"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A property defining mutual knowledge of all orders."@en .

<https://w3id.org/uogto/extensions#ComputationalProblem> a owl:Class ;
    rdfs:label "ComputationalProblem"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A problem computing strategic options."@en .

<https://w3id.org/uogto/extensions#CondorcetWinner> a owl:Class ;
    rdfs:label "CondorcetWinner"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A candidate winning majority preferences head-to-head."@en .

<https://w3id.org/uogto/extensions#ConstraintViolation> a owl:Class ;
    rdfs:label "ConstraintViolation"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Output logs reporting model schema errors."@en .

<https://w3id.org/uogto/extensions#ContextWindow> a owl:Class ;
    rdfs:label "ContextWindow"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The input history buffer of a language model."@en .

<https://w3id.org/uogto/extensions#CyberPhysicalState> a owl:Class ;
    rdfs:label "CyberPhysicalState"@en ;
    rdfs:subClassOf ns1:State ;
