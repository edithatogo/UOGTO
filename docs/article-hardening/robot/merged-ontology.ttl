    rdfs:subClassOf ns1:Rule ;
    skos:definition "Rules defining final states."@en .

<https://w3id.org/uogto/extensions#Thing> a owl:Class ;
    rdfs:label "Thing"@en ;
    rdfs:subClassOf ns1:GameEntity,
        <https://www.w3.org/2019/wot/td#Thing> ;
    skos:definition "The physical device or asset counterpart."@en .

<https://w3id.org/uogto/extensions#TransitionNode> a owl:Class ;
    rdfs:label "TransitionNode"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Graph node representing event transitions."@en .

<https://w3id.org/uogto/extensions#TypeSpace> a owl:Class ;
    rdfs:label "TypeSpace"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A space grouping player types."@en .

<https://w3id.org/uogto/extensions#Violation> a owl:Class ;
    rdfs:label "Violation"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An event trace marking rule breach."@en .

<https://w3id.org/uogto/extensions#WardropEquilibrium> a owl:Class ;
    rdfs:label "WardropEquilibrium"@en ;
    rdfs:subClassOf ns1:Equilibrium ;
    skos:definition "The network equilibrium condition where route costs equalize."@en .

<https://w3id.org/uogto/extensions#WitnessStrategy> a owl:Class ;
    rdfs:label "WitnessStrategy"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A strategy proving a temporal property."@en .

ns1:DecisionNode a owl:Class ;
    rdfs:label "Decision Node"@en ;
    rdfs:subClassOf ns1:GameNode ;
    skos:definition "A game node controlled by a specific player."@en .

ns1:Payoff a owl:Class ;
    rdfs:label "Payoff"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The numerical rewards or utilities distributed to players for an outcome."@en .

ns1:PayoffProfile a owl:Class ;
    rdfs:label "Payoff Profile"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Represents the aggregated profile of payoffs for all active players."@en .

ns1:PlayerPayoffLink a owl:Class ;
    rdfs:label "Player Payoff Link"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Connects a utility value directly to a player instance."@en .

ns1:StrategyProfile a owl:Class ;
    rdfs:label "Strategy Profile"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A vector of strategies, one for each player."@en .

ns1:TransitionFunction a owl:Class ;
    rdfs:label "Transition Function"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A function defining the state transitions."@en .

<https://w3id.org/uogto/extensions#AlgorithmicGame> a owl:Class ;
    rdfs:label "AlgorithmicGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game evaluated under computational complexity metrics."@en .

<https://w3id.org/uogto/extensions#Allocation> a owl:Class ;
    rdfs:label "Allocation"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An assignment of goods or resources to agents."@en .

<https://w3id.org/uogto/extensions#BoundedRationalityModel> a owl:Class ;
    rdfs:label "BoundedRationalityModel"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Models capturing cognitive resource bounds."@en .

<https://w3id.org/uogto/extensions#Candidate> a owl:Class ;
    rdfs:label "Candidate"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An option or entity being voted on."@en .

<https://w3id.org/uogto/extensions#CharacteristicFunction> a owl:Class ;
    rdfs:label "Characteristic Function"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A mapping from coalitions to their security payoffs."@en .

<https://w3id.org/uogto/extensions#Contract> a owl:Class ;
    rdfs:label "Contract"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The binding document detailing incentives."@en .

<https://w3id.org/uogto/extensions#Defender> a owl:Class ;
    rdfs:label "Defender"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The player defending resources."@en .

<https://w3id.org/uogto/extensions#DisclosureAction> a owl:Class ;
    rdfs:label "DisclosureAction"@en ;
    rdfs:subClassOf ns1:Action ;
    skos:definition "Action exposing private attributes."@en .

<https://w3id.org/uogto/extensions#EvolutionaryGame> a owl:Class ;
    rdfs:label "EvolutionaryGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game modeling biological or social strategy evolution."@en .

<https://w3id.org/uogto/extensions#IncentiveScheme> a owl:Class ;
    rdfs:label "IncentiveScheme"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A system tying payments to performance indicators."@en .

<https://w3id.org/uogto/extensions#Institution> a owl:Class ;
    rdfs:label "Institution"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A set of formal or informal rules structure."@en .

<https://w3id.org/uogto/extensions#InteractionAffordance> a owl:Class ;
    rdfs:label "InteractionAffordance"@en ;
    rdfs:subClassOf ns1:GameEntity,
        <https://www.w3.org/2019/wot/td#InteractionAffordance> ;
    skos:definition "Action capabilities exposed by a Digital Twin."@en .

<https://w3id.org/uogto/extensions#Matching> a owl:Class ;
    rdfs:label "Matching"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A mapping of agents on one side of the market to another."@en .

<https://w3id.org/uogto/extensions#MultiAgentEnvironment> a owl:Class ;
    rdfs:label "MultiAgentEnvironment"@en ;
    rdfs:subClassOf ns1:Agent ;
    skos:definition "The simulator environment containing states and transition dynamics."@en .

<https://w3id.org/uogto/extensions#NetworkGame> a owl:Class ;
    rdfs:label "NetworkGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game played over a social or physical network graph."@en .

<https://w3id.org/uogto/extensions#Place> a owl:Class ;
    rdfs:label "Place"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Graph node representing local states or resources."@en .

<https://w3id.org/uogto/extensions#PriceOfAnarchy> a owl:Class ;
    rdfs:label "PriceOfAnarchy"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The ratio of worst-case Nash utility to social optimum."@en .

<https://w3id.org/uogto/extensions#PriceOfStability> a owl:Class ;
    rdfs:label "PriceOfStability"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The ratio of best-case Nash utility to social optimum."@en .

<https://w3id.org/uogto/extensions#PrivacyBudget> a owl:Class ;
    rdfs:label "PrivacyBudget"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Numeric index tracking epsilon differential privacy bounds."@en .

<https://w3id.org/uogto/extensions#ReputationScore> a owl:Class ;
    rdfs:label "ReputationScore"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Models statistical estimation of agent trustworthiness."@en .

<https://w3id.org/uogto/extensions#RoutingGame> a owl:Class ;
    rdfs:label "RoutingGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A congestion game played over a network flow path."@en .

<https://w3id.org/uogto/extensions#SignalStructure> a owl:Class ;
    rdfs:label "SignalStructure"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A mapping from state of nature to signals."@en .

<https://w3id.org/uogto/extensions#StateEquation> a owl:Class ;
    rdfs:label "StateEquation"@en ;
    rdfs:subClassOf ns1:State ;
    skos:definition "A differential equation defining state updates."@en .

<https://w3id.org/uogto/extensions#StrategicFormula> a owl:Class ;
    rdfs:label "StrategicFormula"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A temporal logic formula mapping strategy requirements."@en .

<https://w3id.org/uogto/extensions#Target> a owl:Class ;
    rdfs:label "Target"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The target resource with defense payoffs."@en .

<https://w3id.org/uogto/extensions#ToolInvocation> a owl:Class ;
    rdfs:label "ToolInvocation"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An agent action invoking external APIs."@en .

<https://w3id.org/uogto/extensions#TransactionCost> a owl:Class ;
    rdfs:label "TransactionCost"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Utility costs associated with trade execution."@en .

<https://w3id.org/uogto/extensions#Voter> a owl:Class ;
    rdfs:label "Voter"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A player expressing choices over candidates."@en .

ns1:GameNode a owl:Class ;
    rdfs:label "Game Node"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A state configuration node within dynamic/extensive games."@en .

ns1:InformationSet a owl:Class ;
    rdfs:label "Information Set"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A set of decision states indistinguishable to a player."@en .

ns1:Outcome a owl:Class ;
    rdfs:label "Outcome"@en ;
    rdfs:subClassOf prov:Entity,
        ns1:GameEntity ;
    skos:definition "The end consequence of action choices."@en .

<https://w3id.org/uogto/extensions#CausalModel> a owl:Class ;
    rdfs:label "CausalModel"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A model encapsulating structural causal equations."@en .

<https://w3id.org/uogto/extensions#ContinuousTimeGame> a owl:Class ;
    rdfs:label "ContinuousTimeGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game modeling continuous state variables and decisions."@en .

<https://w3id.org/uogto/extensions#ContractGame> a owl:Class ;
    rdfs:label "ContractGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game modeling strategic principal-agent contracts."@en .

<https://w3id.org/uogto/extensions#InformationDesignGame> a owl:Class ;
    rdfs:label "InformationDesignGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game modeling how information is formatted and disclosed."@en .

<https://w3id.org/uogto/extensions#LLMAgent> a owl:Class ;
    rdfs:label "LLMAgent"@en ;
    rdfs:subClassOf ns1:Agent ;
    skos:definition "A language model agent behaving strategically."@en .

<https://w3id.org/uogto/extensions#MatchingMarket> a owl:Class ;
    rdfs:label "MatchingMarket"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A market matching demand and supply agents."@en .

<https://w3id.org/uogto/extensions#MeanFieldGame> a owl:Class ;
    rdfs:label "MeanFieldGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game modeling interactions in infinite agent populations."@en .

<https://w3id.org/uogto/extensions#PopulationState> a owl:Class ;
    rdfs:label "PopulationState"@en ;
    rdfs:subClassOf ns1:State ;
    skos:definition "A continuous distribution of players across states."@en .

<https://w3id.org/uogto/extensions#Resource> a owl:Class ;
    rdfs:label "Resource"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An asset consumed or shared by players."@en .

<https://w3id.org/uogto/extensions#SecurityGame> a owl:Class ;
    rdfs:label "SecurityGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game modeling strategic defense and attacks."@en .

<https://w3id.org/uogto/extensions#VotingGame> a owl:Class ;
    rdfs:label "VotingGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game representing voting procedures and aggregation."@en .

<https://w3id.org/uogto/extensions#ComplianceState> a owl:Class ;
    rdfs:label "ComplianceState"@en ;
    rdfs:subClassOf ns1:State ;
    skos:definition "A state marking compliance with norms."@en .

<https://w3id.org/uogto/extensions#DigitalTwin> a owl:Class ;
    rdfs:label "DigitalTwin"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The digital replica mapping physical device parameters."@en .

<https://w3id.org/uogto/extensions#ExecutionBinding> a owl:Class ;
    rdfs:label "ExecutionBinding"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "Mappers mapping ontology elements to software execution objects."@en .

<https://w3id.org/uogto/extensions#GraphPlayer> a owl:Class ;
    rdfs:label "GraphPlayer"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A node in a network game."@en .

<https://w3id.org/uogto/extensions#ModelCheckingTask> a owl:Class ;
    rdfs:label "ModelCheckingTask"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A model verification execution run."@en .

<https://w3id.org/uogto/extensions#OpenGame> a owl:Class ;
    rdfs:label "OpenGame"@en ;
    rdfs:subClassOf <https://w3id.org/opengames#OpenGame>,
        ns1:GameSpecification ;
    skos:definition "A game block that can compose with other games."@en .

<https://w3id.org/uogto/extensions#PetriNet> a owl:Class ;
    rdfs:label "PetriNet"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The discrete-event bipartite graph representation."@en .

<https://w3id.org/uogto/extensions#Population> a owl:Class ;
    rdfs:label "Population"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The group of agents evolving strategies."@en .

<https://w3id.org/uogto/extensions#Type> a owl:Class ;
    rdfs:label "Type"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An agent type representing beliefs and preferences."@en .

ns1:PlaySession a owl:Class ;
    rdfs:label "Play Session"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A session during which a game instance is played or simulated."@en .

<https://w3id.org/uogto/extensions#Auction> a owl:Class ;
    rdfs:label "Auction"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A mechanism for selling or buying goods via bidding."@en .

<https://w3id.org/uogto/extensions#BargainingGame> a owl:Class ;
    rdfs:label "BargainingGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A cooperative scenario where players negotiate a division of resources."@en .

<https://w3id.org/uogto/extensions#LearningProcess> a owl:Class ;
    rdfs:label "LearningProcess"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "An iterative process of strategy updates in repeated play."@en .

<https://w3id.org/uogto/extensions#Mechanism> a owl:Class ;
    rdfs:label "Mechanism"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A system specifying rules for mapping agent messages to allocations and payments."@en .

<https://w3id.org/uogto/extensions#RuleEncodedGame> a owl:Class ;
    rdfs:label "RuleEncodedGame"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game completely defined by syntax rules."@en .

<https://w3id.org/uogto/extensions#CooperativeGame> a owl:Class ;
    rdfs:label "Cooperative Game"@en ;
    rdfs:subClassOf ns1:GameSpecification ;
    skos:definition "A game where players can negotiate binding agreements."@en .

ns1:Action a owl:Class ;
    rdfs:label "Action"@en ;
    rdfs:subClassOf prov:Activity,
        schema:Action,
        ns1:GameEntity ;
    skos:definition "A single choice or move available to a player at a decision point."@en .

ns1:OntologyGovernanceRecord a owl:Class ;
    rdfs:label "Ontology governance record"@en ;
    skos:definition "A record that captures repository-level governance metadata for UOGTO."@en .

ns1:Strategy a owl:Class ;
    rdfs:label "Strategy"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A complete plan of action for a player."@en .

ns1:Agent a owl:Class ;
    rdfs:label "Agent"@en ;
    rdfs:subClassOf prov:Agent,
        <https://spec.modelcontextprotocol.io/schema#Client>,
        ns1:GameEntity ;
    skos:definition "An automated or rational actor operating inside a game."@en .

ns1:State a owl:Class ;
    rdfs:label "State"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A configuration node in extensive-form or dynamic games."@en .

ns1:Equilibrium a owl:Class ;
    rdfs:label "Equilibrium"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A strategy profile matching equilibrium conditions (e.g. Nash)."@en .

ns1:Rule a owl:Class ;
    rdfs:label "Rule"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "A structural constraint governing game play."@en .

ns1:Player a owl:Class ;
    rdfs:label "Player"@en ;
    rdfs:subClassOf schema:Agent,
        ns1:GameEntity ;
    skos:definition "An entity (human, LLM, robot, group) playing the game."@en .

ns1:GameSpecification a owl:Class ;
    rdfs:label "Game Specification"@en ;
    rdfs:subClassOf ns1:GameEntity ;
    skos:definition "The structural rules, players, actions, and utilities defining a game."@en .

<https://w3id.org/uogto/core> a owl:Ontology ;
    rdfs:label "Universal Open Game Theory Ontology (UOGTO) Core"@en ;
    dcterms:creator "UOGTO Contributors" ;
    dcterms:description "The core release ontology for modeling games, strategies, actions, outcomes, payoffs, equilibria, execution traces, and extensible game-theoretic semantics."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:title "Universal Open Game Theory Ontology (UOGTO)"@en ;
    vann:preferredNamespacePrefix "uogto" ;
    vann:preferredNamespaceUri "https://w3id.org/uogto/core#" ;
    owl:versionInfo "1.0.0" ;
    skos:definition "The core schema for modeling games, strategies, actions, outcomes, and payoffs."@en .

ns1:GameEntity a owl:Class ;
    rdfs:label "Game Entity"@en ;
    skos:definition "The base class for all game-theoretic elements."@en .

