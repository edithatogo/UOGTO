@prefix sh: <http://www.w3.org/ns/shacl#> . @prefix uogto: <https://w3id.org/uogto/core#> . @prefix hta: <https://w3id.org/uogto/extensions#> . @prefix mdm: <https://w3id.org/uogto/extensions#> . @prefix safety: <https://w3id.org/uogto/extensions#> . @prefix genomic: <https://w3id.org/uogto/extensions#> .
hta:AppraisalGameShape a sh:NodeShape ; sh:targetClass hta:TechnologyAppraisalGame ; sh:property [ sh:path uogto:governedByRule ; sh:minCount 1 ; sh:class hta:AppraisalThreshold ] ; sh:property [ sh:path uogto:producesOutcome ; sh:minCount 1 ] .
mdm:TreatmentChoiceShape a sh:NodeShape ; sh:targetClass mdm:SharedTreatmentChoiceGame ; sh:property [ sh:path uogto:hasState ; sh:minCount 1 ; sh:class mdm:ClinicalState ] ; sh:property [ sh:path uogto:producesOutcome ; sh:minCount 1 ; sh:class mdm:QualityAdjustedOutcome ] .
safety:SafetyCoordinationShape a sh:NodeShape ; sh:targetClass safety:SafetyCoordinationGame ; sh:property [ sh:path uogto:hasState ; sh:minCount 1 ; sh:class safety:Hazard ] ; sh:property [ sh:path uogto:governedByRule ; sh:minCount 1 ; sh:class safety:SafetyBarrier ] .
genomic:GenomicAccessShape a sh:NodeShape ; sh:targetClass genomic:GenomicDataAccessGame ; sh:property [ sh:path uogto:governedByRule ; sh:minCount 1 ; sh:class genomic:ConsentScope ] ; sh:property [ sh:path uogto:producesOutcome ; sh:minCount 1 ] .
