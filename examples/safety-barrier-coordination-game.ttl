@prefix ex: <http://example.org/applied-pack/> . @prefix safety: <https://w3id.org/uogto/extensions#> . @prefix uogto: <https://w3id.org/uogto/core#> . @prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
ex:safety-coordination a safety:SafetyCoordinationGame ; uogto:identifier "safety-coordination" ; uogto:hasPlayer ex:operator, ex:controller ; uogto:hasState ex:overpressure ; uogto:governedByRule ex:shutdown-barrier ; uogto:producesOutcome ex:safe-shutdown .
ex:operator a uogto:Player ; uogto:identifier "operator" ; uogto:selectsAction ex:trigger-shutdown . ex:controller a uogto:Player ; uogto:identifier "controller" . ex:trigger-shutdown a uogto:Action . ex:overpressure a safety:Hazard . ex:shutdown-barrier a safety:SafetyBarrier .
ex:safe-shutdown a uogto:Outcome ; uogto:assignsPayoff ex:safety-payoff . ex:safety-payoff a uogto:Payoff ; uogto:payoffValue "1.0"^^xsd:double . ex:safety-session a uogto:PlaySession ; uogto:hasState ex:overpressure ; uogto:emitsEventTrace ex:incident-evidence . ex:incident-evidence a safety:IncidentEvidence .
