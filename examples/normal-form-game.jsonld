{
  "@context": "../jsonld/context.jsonld",
  "@id": "http://example.org/normal-form-game",
  "@type": "GameSpecification",
  "identifier": "normal-form",
  "name": "Generic Normal Form Game",
  "hasPlayer": [
    {
      "@id": "http://example.org/players/p1",
      "@type": "Player",
      "identifier": "p1",
      "hasStrategy": {
        "@id": "http://example.org/strategies/cooperate"
      }
    },
    {
      "@id": "http://example.org/strategies/cooperate",
      "@type": "Strategy",
      "identifier": "cooperate"
    }
  ]
}
