{
  "@context": "../jsonld/context.jsonld",
  "@graph": [
    {
      "@id": "http://example.org/uogto/interop/openspiel-matrix-game",
      "@type": [
        "GameSpecification",
        "ExecutableGameGraph"
      ],
      "identifier": "openspiel-matrix-game",
      "name": "OpenSpiel Matrix Game Interoperability Fixture",
      "description": "UOGTO fixture for an OpenSpiel-style two-player matrix game. This asserts a semantic binding pattern, not a completed OpenSpiel round-trip adapter.",
      "hasPlayer": [
        {
          "@id": "http://example.org/uogto/interop/openspiel/row-player"
        },
        {
          "@id": "http://example.org/uogto/interop/openspiel/column-player"
        }
      ],
      "compiledToExecutionModel": {
        "@id": "http://example.org/uogto/interop/openspiel/execution-model"
      },
      "hasExecutionBinding": {
        "@id": "http://example.org/uogto/interop/openspiel/execution-binding"
      },
      "hasStrategyProfile": [
        {
          "@id": "http://example.org/uogto/interop/openspiel/profile-cooperate-cooperate"
        },
        {
          "@id": "http://example.org/uogto/interop/openspiel/profile-defect-cooperate"
        }
      ],
      "https://w3id.org/uogto/core#hasActionSpace": [
        {
          "@id": "http://example.org/uogto/interop/openspiel/row-action-space"
        },
        {
          "@id": "http://example.org/uogto/interop/openspiel/column-action-space"
        }
      ]
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/row-player",
      "@type": "Player",
      "identifier": "row-player",
      "name": "Row Player"
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/column-player",
      "@type": "Player",
      "identifier": "column-player",
      "name": "Column Player"
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/row-action-space",
      "@type": "ActionSpace",
      "identifier": "row-action-space",
      "name": "Row Action Space",
      "https://w3id.org/uogto/core#belongsToPlayer": {
        "@id": "http://example.org/uogto/interop/openspiel/row-player"
      },
      "https://w3id.org/uogto/core#hasAction": [
        {
          "@id": "http://example.org/uogto/interop/openspiel/row-cooperate"
        },
        {
          "@id": "http://example.org/uogto/interop/openspiel/row-defect"
        }
      ]
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/column-action-space",
      "@type": "ActionSpace",
      "identifier": "column-action-space",
      "name": "Column Action Space",
      "https://w3id.org/uogto/core#belongsToPlayer": {
        "@id": "http://example.org/uogto/interop/openspiel/column-player"
      },
      "https://w3id.org/uogto/core#hasAction": [
        {
          "@id": "http://example.org/uogto/interop/openspiel/column-cooperate"
        },
        {
          "@id": "http://example.org/uogto/interop/openspiel/column-defect"
        }
      ]
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/row-cooperate",
      "@type": "Action",
      "identifier": "row-cooperate",
      "name": "Cooperate",
      "https://w3id.org/uogto/core#belongsToPlayer": {
        "@id": "http://example.org/uogto/interop/openspiel/row-player"
      }
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/row-defect",
      "@type": "Action",
      "identifier": "row-defect",
      "name": "Defect",
      "https://w3id.org/uogto/core#belongsToPlayer": {
        "@id": "http://example.org/uogto/interop/openspiel/row-player"
      }
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/column-cooperate",
      "@type": "Action",
      "identifier": "column-cooperate",
      "name": "Cooperate",
      "https://w3id.org/uogto/core#belongsToPlayer": {
        "@id": "http://example.org/uogto/interop/openspiel/column-player"
      }
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/column-defect",
      "@type": "Action",
      "identifier": "column-defect",
      "name": "Defect",
      "https://w3id.org/uogto/core#belongsToPlayer": {
        "@id": "http://example.org/uogto/interop/openspiel/column-player"
      }
    },
    {
      "@id": "http://example.org/uogto/interop/openspiel/profile-cooperate-cooperate",
