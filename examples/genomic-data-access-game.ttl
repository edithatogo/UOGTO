@prefix ex: <http://example.org/applied-pack/> . @prefix genomic: <https://w3id.org/uogto/packs/genomic-policy#> . @prefix uogto: <https://w3id.org/uogto/core#> . @prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
ex:genomic-access a genomic:GenomicDataAccessGame ; uogto:identifier "genomic-access" ; uogto:hasPlayer ex:data-custodian, ex:researcher ; uogto:governedByRule ex:research-consent ; uogto:producesOutcome ex:controlled-access .
ex:data-custodian a uogto:Player ; uogto:identifier "data-custodian" ; uogto:selectsAction ex:grant-access . ex:researcher a uogto:Player ; uogto:identifier "researcher" . ex:grant-access a uogto:Action . ex:research-consent a genomic:ConsentScope . ex:sequence-data a genomic:GenomicDataCategory .
ex:controlled-access a uogto:Outcome ; uogto:assignsPayoff ex:disclosure-risk . ex:disclosure-risk a genomic:DisclosureRisk ; uogto:payoffValue "-0.15"^^xsd:double . ex:genomic-state a uogto:State . ex:genomic-session a uogto:PlaySession ; uogto:hasState ex:genomic-state ; uogto:emitsEventTrace ex:genomic-trace . ex:genomic-trace a uogto:EventTrace .
