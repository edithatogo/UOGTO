ex:treatment-choice a mdm:SharedTreatmentChoiceGame ; uogto:identifier "treatment-choice" ; uogto:hasPlayer ex:patient, ex:clinician ; uogto:hasState ex:uncertain-response ; uogto:producesOutcome ex:quality-adjusted-result .
ex:patient a uogto:Player ; uogto:identifier "patient" ; uogto:hasAvailableAction ex:treatment-a, ex:treatment-b ; uogto:selectsAction ex:treatment-a . ex:clinician a uogto:Player ; uogto:identifier "clinician" . ex:treatment-a a mdm:TreatmentOption . ex:treatment-b a mdm:TreatmentOption . ex:uncertain-response a mdm:ClinicalState .
